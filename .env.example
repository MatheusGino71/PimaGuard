# ============================================================================
# PimaGuard - Configuração de Ambiente
# ============================================================================
# Copie este arquivo para .env e customize conforme necessário
# cp .env.example .env

# ============================================================================
# SERVIDOR
# ============================================================================

# Porta do servidor FastAPI
PORT=8000

# Host (0.0.0.0 para aceitar conexões externas)
HOST=0.0.0.0

# Número de workers (para produção com gunicorn)
WORKERS=4

# ============================================================================
# APLICAÇÃO
# ============================================================================

# Modo debug (Development/Production)
DEBUG=True

# Secret key para segurança (gere uma aleatória em produção)
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# Origens permitidas (separadas por vírgula)
# * = todas as origens
CORS_ORIGINS=*

# ============================================================================
# BANCO DE DADOS (Futuro)
# ============================================================================

# DATABASE_URL=postgresql://user:password@localhost:5432/pimaguard

# ============================================================================
# AUTENTICAÇÃO (Futuro)
# ============================================================================

# JWT_SECRET=your-jwt-secret-key-here
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24

# ============================================================================
# CAMINHOS
# ============================================================================

# Caminho para dados
DATA_PATH=./data

# Caminho para modelos treinados
MODEL_PATH=./models

# ============================================================================
# LOGGING
# ============================================================================

# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Arquivo de log (deixe em branco para apenas console)
LOG_FILE=logs/pimaguard.log

# ============================================================================
# CACHE (Futuro)
# ============================================================================

# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# RATE LIMITING (Futuro)
# ============================================================================

# RATE_LIMIT_ENABLED=False
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD=3600

# ============================================================================
# KAGGLE (Dataset Download)
# ============================================================================

# Use automaticamente kagglehub (requer autenticação)
# KAGGLE_USERNAME=your-username
# KAGGLE_KEY=your-api-key

# ============================================================================
# MACHINE LEARNING
# ============================================================================

# Random seed para reprodutibilidade
ML_RANDOM_SEED=42

# Tamanho do test set (0-1)
ML_TEST_SIZE=0.2

# Número de estimadores Random Forest
ML_RF_N_ESTIMATORS=100

# Profundidade máxima Random Forest
ML_RF_MAX_DEPTH=10

# ============================================================================
# SHAP
# ============================================================================

# Número de samples para SHAP KernelExplainer
SHAP_SAMPLE_SIZE=50

# ============================================================================
# NOTIFICAÇÕES (Futuro)
# ============================================================================

# SENDGRID_API_KEY=your-sendgrid-key
# SLACK_WEBHOOK_URL=your-slack-webhook

# ============================================================================
# MONITORAMENTO (Futuro)
# ============================================================================

# SENTRY_DSN=your-sentry-dsn
# DATADOG_API_KEY=your-datadog-key

# ============================================================================
# NOTAS
# ============================================================================
# 
# Para desenvolvimento local:
#   1. Copie este arquivo para .env
#   2. Customize conforme necessário
#   3. Não commit .env em git (já está em .gitignore)
#
# Para produção:
#   1. Gere SECRET_KEY aleatória: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   2. Configure DATABASE_URL com credenciais seguras
#   3. Defina DEBUG=False
#   4. Configure variáveis de produção
#   5. Use gerenciador de secrets (AWS Secrets Manager, Azure KeyVault, etc)
#
